{
  "$schema": "https://turbopack.org/json/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.js", "test/**/*.ts"]
    }
  }
}
